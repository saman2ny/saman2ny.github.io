---
import "../styles/global.css";
import SiteDoodles from "../components/SiteDoodles.astro";

interface Props {
	title?: string;
}

const { title = "Sam Antony" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<SiteDoodles />
		<slot />
	</body>
</html>
